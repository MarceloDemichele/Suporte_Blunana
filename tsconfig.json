{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "*.ts",
    "config/**/*.ts",
    "crawler-interface/**/*.ts",
    "external-agent/**/*.ts"
  ]
}
