{
  "name": "rocha-robo-cef-publicacoes",
  "version": "1.0.0",
  "description": "Aplicacao console .NET para automatizar consulta de publicacoes no portal juridico da Caixa, importar novas publicacoes para MySQL e enviar resumo de processamento por Slack e WhatsApp.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run screens:prod",
    "agent:cef": "ts-node external-agent/index.ts",
    "agent:ask": "ts-node external-agent/index.ts",
    "agent:index": "ts-node external-agent/tools/build-index.ts",
    "agent:server": "ts-node external-agent/api/server.ts",
    "docs:prod": "cross-env APP_ENV=prod ts-node crawler-interface/test-screens.ts",
    "reverse:prod": "cross-env APP_ENV=prod ts-node crawler-interface/reverse-prod.ts",
    "crawler:dev": "cross-env APP_ENV=dev ts-node crawler.ts",
    "crawler:hml": "cross-env APP_ENV=hml ts-node crawler.ts",
    "crawler:prod": "cross-env APP_ENV=prod ts-node crawler.ts",
    "login:dev": "cross-env APP_ENV=dev ts-node crawler-interface/test-login.ts",
    "login:hml": "cross-env APP_ENV=hml ts-node crawler-interface/test-login.ts",
    "login:prod": "cross-env APP_ENV=prod ts-node crawler-interface/test-login.ts",
    "menu:dev": "cross-env APP_ENV=dev ts-node crawler-interface/test-menu.ts",
    "menu:hml": "cross-env APP_ENV=hml ts-node crawler-interface/test-menu.ts",
    "menu:prod": "cross-env APP_ENV=prod ts-node crawler-interface/test-menu.ts",
    "screens:dev": "cross-env APP_ENV=dev ts-node crawler-interface/test-screens.ts",
    "screens:hml": "cross-env APP_ENV=hml ts-node crawler-interface/test-screens.ts",
    "screens:prod": "cross-env APP_ENV=prod ts-node crawler-interface/test-screens.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "otplib": "^13.4.1"
  }
}
